                    // defaultListener // listener factory
// );

conv = new ConvergenceSpec(
	"Product.Yield.noFIRE", // string pattern
	1.0E-4, // percent change
	0.1, // multiplier, how close the means between sample tests have to be
	100000 //sample size on which the test is performed to compare means
);

s = new ScenarioSet(1.0E-5, // improvement
                    500000, // iterations
                    1000000, // checkpoint count
                    false, // make zip file
					new ConvergenceSpec[] {conv}, // Convergence method
					defaultListener // listener factory
);
	
 // Max Yield
 s.addScenario("Output/001_AAC_max", // scenario name
	"Max Yield for Total Harvest. Informs even flow and settings for flow ratio accounts.", // scenario description
	new TargetDescription[] {
		// add TargetDescription objects here
		cancelTreatments,
		Flow_GS(1),
		//Flow_HarvestEVEN(1,1,20,periods),
		THLB4070(1e7),
		//Routes(1e-8),
		//Patches(1,100,10000,1e7),
		GRNUP(100),
		BIOD(1000),
		ECA(1000),
		UWR(1000,1000),
		VQO(1000)
		
		}
	);

/*
 * Show the menu and conditionally run the scenarios
