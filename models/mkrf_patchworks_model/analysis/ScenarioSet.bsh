/*
 * Load in the target descriptions
 * Uncomment this line to load in a custom set.
 */
sourceRelative("../InitialTargets/00_Target_Descriptions.bsh");

/*
 * Default ScenarioChangeListener factory
 * Customize this object to intervene in the scenario life cycle.
 */
defaultListener = new ChangeListenerFactory() {
      public ScenarioChangeListener createListener(ScenarioDescription sd) {
         return new ScenarioChangeListener(sd) {
            int counter = 0;
			HashSet flows = new HashSet();
			resetInterval = 2;
			treatStartPeriod = 1;
			if (sd.getUserArg() != null)
				treatStartPeriod = ((Integer)sd.getUserArg()).intValue();

            public void init() {
               /*
                * When the model starts up turn off the flow targets
                * because they interfere with the initial allocation.
                */
               counter = 0;
               IProperties.logEvent("ScenarioSet", "De-activate flow targets");
	       flows.clear();
	       it = control.getTargetLabels().iterator();
	       while(it.hasNext()) {
			   t = control.getTarget(it.next());
			   if (t.isActive() && t.getLabel().matches("^(route.ratio|Product.Flow|Feature.Flow|Feature.Ratio|Product.Ratio|Product.Area|Patch).*")) {
				   flows.add(t);
				   t.setActive(false);
				}
			}
			
			// set active again total harvest
			t = control.getTarget("Product.Yield.noFIRE");
			t.setActive(true);
			t = control.getTarget("Product.Area.TREAT.FIRE");
			t.setActive(true);
		   
            }
         
            public boolean evaluateBefore() {
               /*
                * After the model has been running for a short while turn the 
                * flow targets back on.
                */
				counter++;
				if (counter == 1) {
					IProperties.logEvent("ScenarioSet", "Re-activate flow targets");
					it = flows.iterator();
					while(it.hasNext()) {
						t = it.next();
						t.setActive(true);
					}
				}
				return false;
            }
         
            public boolean evaluateAfter(boolean finished, 
                                         ScenarioMonitor monitor) {

               if (counter == 0)
                  finished = false;
               counter++;
               return finished;
            }

            public void wrapup(boolean interrupted) {
               /*
                * After the scenario has been saved out take care of any
                * post-processing
                */
               // if (!interrupted) 
               //    makeAnimations(sd.getLabel());
            }
         };
      }
   };

